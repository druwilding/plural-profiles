= form_with model: theme, url: (theme.persisted? ? our_theme_path(theme) : our_themes_path), method: (theme.persisted? ? :patch : :post) do |form|
  - if theme.errors.any?
    .error-messages
      - theme.errors.full_messages.each do |message|
        %p= message

  .form-group
    = form.label :name
    = form.text_field :name, required: true, maxlength: 255,
      data: { "theme-designer-target": "nameInput", action: "input->theme-designer#updateJsonOutput" }

  - Theme::PROPERTY_GROUPS.each do |group_key, group_label|
    %hr.form-divider
    %h3= group_label
    - Theme::THEMEABLE_PROPERTIES.select { |_, v| v[:group] == group_key }.each do |prop, meta|
      .form-group.theme-designer__color-group
        %label{for: "theme_colors_#{prop}"}= meta[:label]
        .theme-designer__color-input
          %input{type: "color", alpha: true, name: "theme[colors][#{prop}]", value: theme.color_for(prop), id: "theme_colors_#{prop}", data: { "theme-designer-target": "colorInput", property: prop, action: "input->theme-designer#updatePreview" }}
          %input.theme-designer__hex-input{type: "text", name: "theme[colors][#{prop}]", value: theme.color_for(prop), maxlength: 9, pattern: "#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?", aria: { label: "#{meta[:label]} hex" }, data: { "theme-designer-target": "hexInput", property: prop, action: "input->theme-designer#updateFromHex" }}

  %hr.form-divider
  %details
    %summary Background image
    .form-group
      = form.label :background_image, "Background image (JPG, PNG, or WebP, up to 2 MB)"
      = form.file_field :background_image, accept: "image/jpeg, image/png, image/webp",
        data: { "theme-designer-target": "backgroundFileInput", action: "change->theme-designer#previewBackgroundImage" }
      %p.form-hint Choose an image that doesn't reduce text readability with your chosen colours.
      - if theme.persisted? && theme.background_image.attached?
        %p.form-hint Current background:
        = image_tag theme.background_image.variant(resize_to_limit: [ 200, 200 ]),
          class: "theme-bg-preview", width: 200, alt: "Current background image", loading: "lazy"
        %label.checkbox-label
          = check_box_tag "theme[remove_background_image]", "1", false
          Remove background image

    .form-group
      = form.label :background_repeat, "Repeat"
      = form.select :background_repeat,
        Theme::BACKGROUND_REPEAT_OPTIONS.map { |v| [ v, v ] },
        {}, { data: { "theme-designer-target": "backgroundRepeat", action: "change->theme-designer#updateBackgroundPreview" } }

    .form-group
      = form.label :background_size, "Size"
      = form.select :background_size,
        Theme::BACKGROUND_SIZE_OPTIONS.map { |v| [ v.capitalize, v ] },
        {}, { data: { "theme-designer-target": "backgroundSize", action: "change->theme-designer#updateBackgroundPreview" } }

    .form-group
      = form.label :background_position, "Position"
      = form.select :background_position,
        Theme::BACKGROUND_POSITION_OPTIONS.map { |v| [ v.capitalize, v ] },
        {}, { data: { "theme-designer-target": "backgroundPosition", action: "change->theme-designer#updateBackgroundPreview" } }

    .form-group
      = form.label :background_attachment, "Scroll behaviour"
      = form.select :background_attachment,
        [[ "Scroll (moves with content)", "scroll" ], [ "Fixed (stays in place)", "fixed" ]],
        {}, { data: { "theme-designer-target": "backgroundAttachment", action: "change->theme-designer#updateBackgroundPreview" } }

  %hr.form-divider
  %details
    %summary Tags
    = hidden_field_tag "theme[tags][]", ""
    .checkbox-list
      - Theme::TAGS.each do |value, label|
        %label.checkbox-label
          = check_box_tag "theme[tags][]", value, theme.tags.include?(value),
            data: { "theme-designer-target": "tagInput", action: "change->theme-designer#updateJsonOutput" }
          = label

  %hr.form-divider
  %details
    %summary Share theme
    - if Current.user.admin?
      .form-group
        %label.checkbox-label
          = form.check_box :shared
          Shared theme
          %span.admin-badge admin
    - if Current.user.admin? && theme.shared?
      .form-group
        %label.checkbox-label
          = form.check_box :site_default
          Default theme
          %span.admin-badge admin
    .form-group
      = form.label :credit, "Made by"
      = form.text_field :credit, maxlength: 255,
        data: { "theme-designer-target": "creditInput", action: "input->theme-designer#updateJsonOutput" }
    .form-group
      = form.label :credit_url, "Made by link"
      = form.url_field :credit_url, maxlength: 255, placeholder: "https://",
        data: { "theme-designer-target": "creditUrlInput", action: "input->theme-designer#updateJsonOutput" }
    .form-group
      = form.label :notes, "Notes"
      = form.text_area :notes, rows: 4,
        data: { "theme-designer-target": "notesInput", action: "input->theme-designer#updateJsonOutput" }

  .form-group{style: "margin-top: 2rem;"}
    = form.submit(theme.persisted? ? "Save theme" : "Create theme")
