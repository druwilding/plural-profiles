- content_for(:title) { "Themes — Plural Profiles" }

%h1 Themes

- if @active_theme
  %details.theme-section{open: true, data: { controller: "details-persist", "details-persist-key-value": "active-theme" }}
    %summary.theme-section__summary Active theme
    .card-list
      = render "our/themes/theme_card", theme: @active_theme, section: "active"

.theme-tag-filter
  %span.theme-tag-filter__label Filter themes by tags:
  - Theme::TAGS.each do |value, label|
    - active = @filter_tags.include?(value)
    - new_tags = active ? @filter_tags - [value] : @filter_tags + [value]
    = link_to label, our_themes_path(tags: new_tags), class: "tag tag--filter #{'tag--filter-active' if active}"
  - if @filter_tags.any?
    = link_to "Clear filter", our_themes_path, class: "theme-tag-filter__clear"


%details.theme-section{open: true, data: { controller: "details-persist", "details-persist-key-value": "our-themes" }}
  %summary.theme-section__summary Our themes

  .theme-import{data: { controller: "theme-import", "theme-import-new-url-value": new_our_theme_path }}
    = link_to "New theme", new_our_theme_path, class: "btn"
    %button.btn.btn--outline{type: "button", data: { action: "click->theme-import#open" }} Import theme

    %dialog.import-dialog{data: { "theme-import-target": "dialog", action: "click->theme-import#backdropClick" }}
      %form{data: { action: "submit->theme-import#import" }}
        %h2 Import theme
        %p Paste a theme JSON export below (or a legacy CSS block).
        %textarea.import-dialog__textarea{data: { "theme-import-target": "cssInput" }, rows: 12, placeholder: "{\n  \"plural_profiles_theme\": 1,\n  \"name\": \"My theme\",\n  \"colors\": { ... }\n}", spellcheck: false}
        %p.import-dialog__error{data: { "theme-import-target": "error" }, role: "alert"}
        .import-dialog__actions
          %button.btn{type: "submit"} Import
          %button.btn.btn--secondary{type: "button", data: { action: "click->theme-import#close" }} Cancel

  - if @our_themes.any?
    .card-list
      - @our_themes.each do |theme|
        = render "our/themes/theme_card", theme: theme, section: "our"
  - elsif @filter_tags.any?
    .card
      %p No themes match the selected tags.
  - elsif @active_theme.nil?
    .card
      %p You haven't created any themes yet. Themes let you customise the colours used across the site.


- if @any_shared_themes
  %details.theme-section{open: true, data: { controller: "details-persist", "details-persist-key-value": "shared-themes" }}
    %summary.theme-section__summary Shared themes
    - if @shared_themes.any?
      .card-list
        - @shared_themes.each do |theme|
          = render "our/themes/theme_card", theme: theme, section: "shared"
    - elsif @filter_tags.any?
      .card
        %p No themes match the selected tags.
