- content_for(:title) { "Edit #{@theme.name} — Plural Profiles" }
- content_for(:container_class, "theme-designer-container")

%h1 Edit theme

.theme-designer{data: { controller: "theme-designer", "theme-designer-derived-text-properties-value": Theme::DERIVED_TEXT_PROPERTIES.to_json }}
  .theme-designer__controls
    .card
      = render "our/themes/form", theme: @theme

    .card{data: { controller: "clipboard" }}
      %details
        %summary Export theme
        %p.text-muted Copy this JSON to share your theme with others.
        .form-group
          %textarea.theme-designer__css-output{readonly: true, rows: 12, data: { "theme-designer-target": "jsonOutput", "clipboard-target": "source" }}= @theme.to_export_json
        %button.btn.btn--secondary{data: { action: "click->clipboard#copy" }}
          %span{data: { "clipboard-target": "label" }} Copy JSON
          %span{aria: {hidden: "true"}} ⧉

  .theme-designer__preview
    - bg_style = @theme.background_image.attached? ? " #{@theme.background_css_properties(rails_storage_proxy_url(@theme.background_image))}" : ""
    - existing_bg_url = @theme.background_image.attached? ? rails_storage_proxy_url(@theme.background_image) : nil
    .theme-preview{style: "#{@theme.to_css_properties}#{bg_style}",
      data: { "theme-designer-target": "preview", "existing-bg-url": existing_bg_url }}
      = render "our/themes/preview"

%p= link_to "← Back to themes", our_themes_path
