- content_for(:title) { "Edit #{@theme.name} — Plural Profiles" }
- content_for(:container_class, "theme-designer-container")

%h1 Edit theme

.theme-designer{data: { controller: "theme-designer" }}
  .theme-designer__controls
    .card
      = render "our/themes/form", theme: @theme

    .card
      %details
        %summary Export theme
        %p.text-muted Copy this CSS to share your theme with others.
        .form-group
          %textarea.theme-designer__css-output{readonly: true, rows: 8, data: { "theme-designer-target": "cssOutput" }}= @theme.to_css
        %button.btn.btn--secondary{data: { action: "click->theme-designer#copyCss" }}
          %span{data: { "theme-designer-target": "copyLabel" }} Copy CSS
          %span{aria: {hidden: "true"}} ⧉

  .theme-designer__preview
    .theme-preview{data: { "theme-designer-target": "preview" }}
      = render "our/themes/preview"

%p= link_to "← Back to themes", our_themes_path
