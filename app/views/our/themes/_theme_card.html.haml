.card.card--stacked{ data: { theme_id: theme.id, theme_section: section } }
  .card__main
    .card__header
      %h3= link_to theme.name, our_theme_path(theme)
      - if Current.user.active_theme_id == theme.id
        = link_to "Deactivate", deactivate_our_themes_path, data: { turbo_method: :patch }, class: "btn btn--small"
      - else
        = link_to "Activate", activate_our_theme_path(theme), data: { turbo_method: :patch }, class: "btn btn--small"
    .card__actions
      = link_to "Preview", our_theme_path(theme), class: "btn btn--small btn--secondary" if theme.shared?
      = link_to "Edit", edit_our_theme_path(theme), class: "btn btn--small btn--secondary" if !theme.shared? || Current.user.admin?
      = link_to "Duplicate", duplicate_our_theme_path(theme), data: { turbo_method: :post }, class: "btn btn--small btn--secondary"
      - if theme.shared?
        - if Current.user.admin?
          - if theme.site_default?
            = link_to "Remove default", set_default_our_theme_path(theme), data: { turbo_method: :patch }, class: "btn btn--small btn--outline"
          - else
            = link_to "Make default", set_default_our_theme_path(theme), data: { turbo_method: :patch }, class: "btn btn--small btn--outline"
      - else
        = link_to "Delete", our_theme_path(theme), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this theme?" }, class: "btn btn--small btn--danger"
  - if theme.credit.present? || theme.credit_url.present? || theme.notes.present? || (theme.shared? && theme.site_default?)
    .card__body
      - if theme.credit.present? || theme.credit_url.present?
        %p.theme-card__credit
          Made by
          - if theme.credit.present? && theme.credit_url.present?
            %strong= link_to theme.credit, theme.credit_url, target: "_blank", rel: "noopener noreferrer"
          - elsif theme.credit.present?
            %strong= theme.credit
          - elsif theme.credit_url.present?
            %strong= link_to theme.credit_url, theme.credit_url, target: "_blank", rel: "noopener noreferrer"
      - if theme.notes.present?
        %p.theme-card__notes= theme.notes
      - if theme.shared? && theme.site_default?
        %span.tag.tag--default Default theme
  - if theme.tags.any?
    .card__tags
      - theme.tags.each do |tag|
        %span.tag.tag--theme= Theme::TAGS[tag] || tag

