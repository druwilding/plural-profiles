- content_for(:title) { "Our profiles — Plural Profiles" }

.card
  .card__header
    %h1 Our profiles

  - if @profiles.any?
    %p= "You have #{pluralize(@profiles.count, "profile")}."

    - if @all_labels.any?
      .filter-bar
        %span.filter-bar__label Filter by label:
        - @all_labels.each do |label|
          = link_to label, our_profiles_path(label: label), class: "btn btn--small #{' btn--secondary' if params[:label] != label}"
        - if params[:label]
          = link_to "Clear filter", our_profiles_path, class: "filter-bar__clear"

  - else
    %p You haven't created any profiles yet.

- if @profiles.any?
  .profile-grid
    - @profiles.each do |profile|
      = render "profile_card", profile: profile
