- if group.errors.any?
  .error-messages
    - group.errors.full_messages.each do |message|
      %p= message

= form_with model: group, url: group.persisted? ? our_group_path(group) : our_groups_path do |form|
  .form-group
    = form.label :name
    = form.text_field :name, required: true

  .form-group
    = form.label :avatar, "Avatar (up to 2 MB)"
    = form.file_field :avatar, accept: "image/jpeg, image/png, image/webp"
    - if group.persisted? && group.avatar.attached?
      %p.form-hint Current avatar:
      = image_tag group.avatar.variant(resize_to_fill: [64, 64]), class: "avatar", width: 64, height: 64, alt: group.avatar_alt_text.presence || "", loading: "lazy"
      %label.checkbox-label
        = check_box_tag "group[remove_avatar]", "1", false
        Remove avatar

  .form-group
    = form.label :avatar_alt_text, "Avatar description"
    = form.text_field :avatar_alt_text, placeholder: "Describe the image for screen readers"

  .form-group
    = form.label :description
    = form.text_area :description, placeholder: "Describe this group...", rows: 18

  .form-group
    = form.label :labels_text, "Labels (optional, comma-separated)"
    = form.text_field :labels_text, value: group.labels_text, placeholder: "e.g. safe, work, close friends"
    %p.form-hint Labels are only visible to you, they never appear on shared pages.

  .form-group
    = form.label :theme_id, "Public theme"
    = form.select :theme_id, grouped_options_for_select(grouped_theme_options(@personal_themes, @shared_themes), group.theme_id), { include_blank: "None (use default)" }, {}
    %p.form-hint Visitors to this group's public page will see this theme. Leave blank for the site default.

  - if group.persisted?
    .form-group
      = form.label :created_at, "Created at (UTC)"
      = form.datetime_local_field :created_at, value: group.created_at.utc.strftime("%Y-%m-%dT%H:%M"), max: Time.current.utc.strftime("%Y-%m-%dT%H:%M")

  .form-group
    = form.submit group.persisted? ? "Update group" : "Create group"
    = link_to "Cancel", group.persisted? ? our_group_path(group) : our_groups_path, class: "btn btn--secondary"
