- content_for(:title) { "Manage profiles in #{@group.name} — Plural Profiles" }

.card
  .card__header
    .name-with-labels
      %h1
        Manage profiles in
        = @group.name
      - if @group.labels.any?
        .label-badges
          - @group.labels.each do |label|
            %span.label-badge= label

  %p Choose which profiles belong to this group. Profiles can belong to more than one group.

- if @group.profiles.any?
  .profile-grid
    - @group.profiles.order_by_name_and_labels.each do |profile|
      = render "our/profiles/profile_card", profile: profile,
          action_label: "Remove from group",
          action_path: remove_profile_our_group_path(@group, profile_id: profile.id),
          action_method: :delete,
          action_class: "btn btn--small btn--danger"

- if @available_profiles.any?
  .profile-grid
    - @available_profiles.each do |profile|
      = render "our/profiles/profile_card", profile: profile,
          action_label: "Add to group",
          action_path: add_profile_our_group_path(@group, profile_id: profile.id),
          action_method: :post,
          action_class: "btn btn--small"

- if @available_profiles.empty? && @group.profiles.empty?
  .card
    %p There are no profiles available to add here right now.
    %p
      You can
      = link_to "create a profile", new_our_profile_path
      first, then come back to add it to this group.
