- content_for(:title) { "Our groups — Plural Profiles" }

.card
  .card__header
    %h1 Our groups

  - if @groups.any?
    %p= "You have #{pluralize(@groups.count, "group")}."

    - if @all_labels.any?
      .filter-bar
        %span.filter-bar__label Filter by label:
        - @all_labels.each do |label|
          = link_to label, our_groups_path(label: label), class: "btn btn--small #{' btn--secondary' if params[:label] != label}"
        - if params[:label]
          = link_to "Clear filter", our_groups_path, class: "filter-bar__clear"

  - else
    %p You haven't created any groups yet.

- if @groups.any?
  .profile-grid
    - @groups.each do |group|
      = render "group_card", group: group
