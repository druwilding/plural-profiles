- content_for(:title) { "Our groups — Plural Profiles" }

%h1 Our groups

- if @groups.any?
  .card-list
    - @groups.each do |group|
      .card.card--row
        .card__header
          - if group.avatar.attached?
            = image_tag group.avatar.variant(resize_to_fill: [48, 48]), class: "avatar avatar--small", width: 48, height: 48, alt: group.avatar_alt_text.presence || "", loading: "lazy"
          %div
            .name-with-labels
              %h2= link_to group.name, our_group_path(group)
              - if group.labels.any?
                .label-badges
                  - group.labels.each do |label|
                    %span.label-badge= label
            %p.text-muted= pluralize(group.profiles.count, "profile")
- else
  .card
    %p You haven't created any groups yet.
