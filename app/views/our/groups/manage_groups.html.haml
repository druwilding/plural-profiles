- content_for(:title) { "Manage groups in #{@group.name} — Plural Profiles" }

- has_tree = @management_tree.any?
- has_root_profiles = @root_profiles.any?

.card
  .card__header
    .name-with-labels
      %h1
        Manage groups in
        = @group.name
      - if @group.labels.any?
        .label-badges
          - @group.labels.each do |label|
            %span.label-badge= label

  %p Choose which groups are nested inside this one. Use the Hide checkboxes to control what's visible on the page that other people see.

  - if has_tree || has_root_profiles
    .tree-editor{"data-controller": "visibility-toggle"}

      -# Root group node (collapsible, no Hide/Remove)
      %details.tree-editor__folder.tree-editor__folder--root{open: true}
        %summary.tree-editor__summary
          .tree-editor__item-info
            - if @group.avatar.attached?
              = image_tag @group.avatar.variant(resize_to_fill: [24, 24]), class: "tree__avatar", width: 24, height: 24, alt: ""
            - else
              %span.tree__avatar.tree__avatar--placeholder{"aria-hidden": "true"}
                = render "shared/plural_pride_logo"
            %span.tree-editor__name= @group.name
            - if @group.labels.any?
              .label-badges
                - @group.labels.each do |label|
                  %span.label-badge= label
        .tree-editor__children
          - if has_tree
            - @management_tree.each do |node|
              = render "our/groups/manage_groups_node", node: node, root_group: @group
          - if has_root_profiles
            - @root_profiles.each do |entry|
              = render "our/groups/manage_groups_profile_node", entry: entry, root_group: @group

- if @available_groups.any?
  .profile-grid
    - @available_groups.each do |group|
      = render "group_card", group: group,
          action_label: "Add to group",
          action_path: add_group_our_group_path(@group, group_id: group.id),
          action_method: :post,
          action_class: "btn btn--small"

- if @available_groups.empty? && !has_tree
  .card
    %p There are no groups available to add here right now.
    %p
      You can
      = link_to "create a group", new_our_group_path
      first, then come back to add it to this group.
